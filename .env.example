# Application Environment
NODE_ENV=development

# Server Configuration
PORT=4000

# Data Source Configuration (options: postgres, synthetic)
DASHBOARD_DATA_SOURCE=postgres

# DHIS2 Configuration (if using DHIS2 as data source)
DHIS2_BASE_URL=
DHIS2_USERNAME=
DHIS2_PASSWORD=
DHIS2_VERIFY_SSL=true
DHIS2_TIMEOUT_MS=15000
COUNTRY_CONFIG_PATH=server/config/country-config.json

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dhis2SierraLeoneDemo
POSTGRES_USER=your_postgres_username
POSTGRES_PASSWORD=your_postgres_password

# API Keys
OPENWEATHER_API_KEY=your_openweather_api_key
ERA5_API_KEY=your_era5_api_key
MAPBOX_API_KEY=your_mapbox_api_key

# Email Configuration
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=your_email@example.com

# ML Service Configuration
ML_SERVICE_URL=http://localhost:8000

# Frontend Environment Variables (must have VITE_ prefix)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key
VITE_PEXELS_API_KEY=your_pexels_api_key
VITE_MAPBOX_TOKEN=your_mapbox_token
