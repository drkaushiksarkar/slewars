    [35mtext[39m: "\n        SELECT\n          ou.uid,\n          ou.name,\n          ou.shortname,\n          ou.code,\n          ou.path,\n          ou.hierarchylevel,\n          ou.parentid,\n          parent.uid as parent_uid,\n          ou.description,\n          ST_AsGeoJSON(ou.geometry) as geometry\n        FROM organisationunit ou\n        LEFT JOIN organisationunit parent ON ou.parentid = parent.organisationunitid\n        WHERE ou.hierarchylevel = $1\n        ORDER BY ou.name\n      "
